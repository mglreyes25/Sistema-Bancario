# Copia este archivo como .env y llena los valores
# Obtén la URL en: Supabase → Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres:[TU_PASSWORD]@db.[TU_PROJECT_REF].supabase.co:5432/postgres"

# Next.js suele ocupar 3000; dejá la API en 3001 (coincide con BACKEND_URL del front)
PORT=3001
