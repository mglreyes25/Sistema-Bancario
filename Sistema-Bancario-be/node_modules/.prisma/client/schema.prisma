// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cuenta {
  id            String        @id @default(uuid())
  nombreTitular String
  saldo         Decimal       @db.Decimal(12, 2)
  creadaEn      DateTime      @default(now())
  transacciones Transaccion[]

  @@map("cuentas")
}

model Transaccion {
  id              String   @id @default(uuid())
  cuentaId        String
  cuenta          Cuenta   @relation(fields: [cuentaId], references: [id])
  tipo            TipoTx // deposito | retiro | comision
  monto           Decimal  @db.Decimal(12, 2)
  justificacion   String?
  comision        Decimal  @default(0) @db.Decimal(12, 2)
  saldoResultante Decimal  @db.Decimal(12, 2)
  fecha           DateTime @default(now())

  @@map("transacciones")
}

enum TipoTx {
  deposito
  retiro
  comision
}
